<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/
C:\Projects\WoW\Bin\Interface\FrameXML\UI.xsd">
	<Script file="MuteClock.lua"/>

	<!-- ============================================================
	     ClockFrame  –  the movable dot indicator
	     ============================================================ -->
	<Frame name="ClockFrame" frameStrata="HIGH" toplevel="true" movable="true" enableMouse="true" parent="UIParent">
		<Size><AbsDimension x="16" y="16"/></Size>
		<Layers>
			<Layer level="BACKGROUND">
				<Texture name="ClockDot" file="Interface\Buttons\WHITE8X8" setAllPoints="true"/>
			</Layer>
			<Layer level="OVERLAY">
				<FontString name="MuteClockBadge" inherits="GameFontNormalSmall" hidden="true">
					<Anchors>
						<Anchor point="TOPRIGHT" relativeTo="$parent">
							<Offset><AbsDimension x="4" y="4"/></Offset>
						</Anchor>
					</Anchors>
					<Shadow><Offset><AbsDimension x="1" y="-1"/></Offset><Color r="0" g="0" b="0" a="1"/></Shadow>
				</FontString>
			</Layer>
		</Layers>
		<Scripts>
			<OnLoad>Clock_OnLoad();</OnLoad>
			<OnUpdate>Clock_OnUpdate(arg1);</OnUpdate>
			<OnEvent>Clock_OnEvent();</OnEvent>
			<OnEnter>doShowTooltip();</OnEnter>
			<OnLeave>GameTooltip:Hide();</OnLeave>
			<OnMouseUp>ClickHandler(arg1, "UP");</OnMouseUp>
			<OnDragStart>ClockFrame_OnDragStart();</OnDragStart>
			<OnDragStop>ClockFrame_OnDragStop();</OnDragStop>
		</Scripts>
	</Frame>

	<!-- ============================================================
	     Config frame   280 x 480

	     Zones:
	       y=   0 .. -28   Title bar
	       y= -28 .. -56   Tab row  (tabs at y=-32, h=22)
	       y= -56 .. -480  Panels   (h=424 each, y=-56)

	     PanelSettings internal layout (y from panel top = 0):
	         0    DivTracking  (h=14)
	        -20   CBAllChars
	        -52   CBNotify
	        -84   DivDisplay
	       -104   CBGroupByCraft
	       -136   CBReadyTime
	       -168   CBOverdue
	       -200   CBLastCrafted
	       -232   DivDot
	       -254   SliderSize   (h=16, visual ~36px including label)
	       -298   CBSmartIcon
	       -330   CBBadge
	       -362   CBHide
	       -404   BtnDefaults  (32px gap, button h=22, bottom=-426)
	     Panel h=424 fits with ~2px to spare. ✓
	     ============================================================ -->
	<Frame name="MuteClockConfigFrame" toplevel="true" parent="UIParent" frameStrata="DIALOG" hidden="true" enableMouse="true" movable="true">
		<Size><AbsDimension x="280" y="480"/></Size>
		<Anchors><Anchor point="CENTER"/></Anchors>
		<Backdrop bgFile="Interface\ChatFrame\ChatFrameBackground" edgeFile="Interface\Tooltips\UI-Tooltip-Border" tile="true">
			<BackgroundInsets><AbsInset left="3" right="3" top="3" bottom="3"/></BackgroundInsets>
			<TileSize><AbsValue val="16"/></TileSize>
			<EdgeSize><AbsValue val="16"/></EdgeSize>
		</Backdrop>
		<Layers>
			<Layer level="OVERLAY">
				<Texture name="MuteClockConfigFrameTopBar" file="Interface\Buttons\WHITE8X8">
					<Size><AbsDimension x="280" y="28"/></Size>
					<Anchors><Anchor point="TOP"/></Anchors>
					<TexCoords left="0" right="1" top="0" bottom="1"/>
				</Texture>
				<FontString name="MuteClockConfigFrameTitle" inherits="GameFontNormal" text="MuteClock">
					<Anchors>
						<Anchor point="TOP" relativeTo="$parent">
							<Offset><AbsDimension x="0" y="-9"/></Offset>
						</Anchor>
					</Anchors>
				</FontString>
			</Layer>
		</Layers>
		<Frames>

			<!-- Tabs — evenly spaced across the width.
			     Frame inner = 280 - 2*8 margin = 264.
			     4 tabs * 60 + 3 gaps * 4 = 252px.  Left margin = (264-252)/2 = 6. -->
			<Button name="$parentBtnTabSettings" inherits="OptionsButtonTemplate" text="Settings">
				<Size><AbsDimension x="60" y="22"/></Size>
				<Anchors>
					<Anchor point="TOPLEFT" relativeTo="$parent">
						<Offset><AbsDimension x="6" y="-32"/></Offset>
					</Anchor>
				</Anchors>
				<Scripts><OnClick>doShowConfigTab("Settings");</OnClick></Scripts>
			</Button>

			<Button name="$parentBtnTabHistory" inherits="OptionsButtonTemplate" text="History">
				<Size><AbsDimension x="60" y="22"/></Size>
				<Anchors>
					<Anchor point="LEFT" relativeTo="$parentBtnTabSettings" relativePoint="RIGHT">
						<Offset><AbsDimension x="4" y="0"/></Offset>
					</Anchor>
				</Anchors>
				<Scripts><OnClick>doShowConfigTab("History");</OnClick></Scripts>
			</Button>

			<Button name="$parentBtnTabCrafters" inherits="OptionsButtonTemplate" text="Crafters">
				<Size><AbsDimension x="60" y="22"/></Size>
				<Anchors>
					<Anchor point="LEFT" relativeTo="$parentBtnTabHistory" relativePoint="RIGHT">
						<Offset><AbsDimension x="4" y="0"/></Offset>
					</Anchor>
				</Anchors>
				<Scripts><OnClick>doShowConfigTab("Crafters");</OnClick></Scripts>
			</Button>

			<Button name="$parentBtnTabNearby" inherits="OptionsButtonTemplate" text="Nearby">
				<Size><AbsDimension x="60" y="22"/></Size>
				<Anchors>
					<Anchor point="LEFT" relativeTo="$parentBtnTabCrafters" relativePoint="RIGHT">
						<Offset><AbsDimension x="4" y="0"/></Offset>
					</Anchor>
				</Anchors>
				<Scripts><OnClick>doShowConfigTab("Nearby");</OnClick></Scripts>
			</Button>

			<!-- Close button -->
			<Button name="$parentBtnClose" inherits="UIPanelCloseButton">
				<Anchors>
					<Anchor point="TOPRIGHT" relativeTo="$parent">
						<Offset><AbsDimension x="0" y="0"/></Offset>
					</Anchor>
				</Anchors>
				<Scripts><OnClick>MuteClockConfigFrame:Hide();</OnClick></Scripts>
			</Button>

			<!-- ============================================================
			     SETTINGS PANEL
			     x=8  y=-56   264 x 424
			     Reset Defaults lives here so it vanishes on other tabs.
			     ============================================================ -->
			<Frame name="$parentPanelSettings">
				<Size><AbsDimension x="264" y="424"/></Size>
				<Anchors>
					<Anchor point="TOPLEFT" relativeTo="$parent">
						<Offset><AbsDimension x="8" y="-56"/></Offset>
					</Anchor>
				</Anchors>
				<Frames>

					<!-- ─── TRACKING ───────────────── y=0 ─── -->
					<Frame name="$parentDivTracking">
						<Size><AbsDimension x="264" y="14"/></Size>
						<Anchors>
							<Anchor point="TOPLEFT" relativeTo="$parent">
								<Offset><AbsDimension x="0" y="0"/></Offset>
							</Anchor>
						</Anchors>
						<Layers>
							<Layer level="OVERLAY">
								<FontString inherits="GameFontNormalSmall" text="TRACKING" justifyH="LEFT">
									<Color r="0.35" g="0.75" b="1"/>
									<Anchors><Anchor point="LEFT"/></Anchors>
								</FontString>
								<Texture name="MuteClockDivTracking" file="Interface\Buttons\WHITE8X8">
									<Size><AbsDimension x="196" y="1"/></Size>
									<Anchors><Anchor point="RIGHT"/></Anchors>
									<TexCoords left="0" right="1" top="0" bottom="1"/>
								</Texture>
							</Layer>
						</Layers>
					</Frame>

					<!-- CBAllChars  y=-20 -->
					<CheckButton name="$parentCBAllChars" inherits="OptionsCheckButtonTemplate">
						<Anchors>
							<Anchor point="TOPLEFT" relativeTo="$parentDivTracking">
								<Offset><AbsDimension x="0" y="-20"/></Offset>
							</Anchor>
						</Anchors>
						<Scripts>
							<OnLoad>getglobal(this:GetName().."Text"):SetText("Track all characters");</OnLoad>
							<OnClick>doConfigSave();</OnClick>
							<OnEnter>ConfigTooltip_Show("Show cooldowns from all your alts,", "not just the current character.");</OnEnter>
							<OnLeave>ConfigTooltip_Hide();</OnLeave>
						</Scripts>
					</CheckButton>

					<!-- CBNotify  y=-52 -->
					<CheckButton name="$parentCBNotify" inherits="OptionsCheckButtonTemplate">
						<Anchors>
							<Anchor point="TOPLEFT" relativeTo="$parentCBAllChars">
								<Offset><AbsDimension x="0" y="-32"/></Offset>
							</Anchor>
						</Anchors>
						<Scripts>
							<OnLoad>getglobal(this:GetName().."Text"):SetText("Chat alert on expiry");</OnLoad>
							<OnClick>doConfigSave();</OnClick>
							<OnEnter>ConfigTooltip_Show("Posts a chat message and plays a sound", "when a cooldown becomes ready.");</OnEnter>
							<OnLeave>ConfigTooltip_Hide();</OnLeave>
						</Scripts>
					</CheckButton>

					<!-- ─── DISPLAY ────────────────── y=-84 ─── -->
					<Frame name="$parentDivDisplay">
						<Size><AbsDimension x="264" y="14"/></Size>
						<Anchors>
							<Anchor point="TOPLEFT" relativeTo="$parentCBNotify">
								<Offset><AbsDimension x="0" y="-32"/></Offset>
							</Anchor>
						</Anchors>
						<Layers>
							<Layer level="OVERLAY">
								<FontString inherits="GameFontNormalSmall" text="DISPLAY" justifyH="LEFT">
									<Color r="0.35" g="0.75" b="1"/>
									<Anchors><Anchor point="LEFT"/></Anchors>
								</FontString>
								<Texture name="MuteClockDivDisplay" file="Interface\Buttons\WHITE8X8">
									<Size><AbsDimension x="204" y="1"/></Size>
									<Anchors><Anchor point="RIGHT"/></Anchors>
									<TexCoords left="0" right="1" top="0" bottom="1"/>
								</Texture>
							</Layer>
						</Layers>
					</Frame>

					<!-- CBGroupByCraft  y=-104 -->
					<CheckButton name="$parentCBGroupByCraft" inherits="OptionsCheckButtonTemplate">
						<Anchors>
							<Anchor point="TOPLEFT" relativeTo="$parentDivDisplay">
								<Offset><AbsDimension x="0" y="-20"/></Offset>
							</Anchor>
						</Anchors>
						<Scripts>
							<OnLoad>getglobal(this:GetName().."Text"):SetText("Group by craft type");</OnLoad>
							<OnClick>doConfigSave();</OnClick>
							<OnEnter>ConfigTooltip_Show("Groups the tooltip and Crafters panel", "by craft type instead of by character.");</OnEnter>
							<OnLeave>ConfigTooltip_Hide();</OnLeave>
						</Scripts>
					</CheckButton>

					<!-- CBReadyTime  y=-136 -->
					<CheckButton name="$parentCBReadyTime" inherits="OptionsCheckButtonTemplate">
						<Anchors>
							<Anchor point="TOPLEFT" relativeTo="$parentCBGroupByCraft">
								<Offset><AbsDimension x="0" y="-32"/></Offset>
							</Anchor>
						</Anchors>
						<Scripts>
							<OnLoad>getglobal(this:GetName().."Text"):SetText("Show ready time");</OnLoad>
							<OnClick>doConfigSave();</OnClick>
							<OnEnter>ConfigTooltip_Show("Shows the clock time when each", "cooldown will be ready.");</OnEnter>
							<OnLeave>ConfigTooltip_Hide();</OnLeave>
						</Scripts>
					</CheckButton>

					<!-- CBOverdue  y=-168 -->
					<CheckButton name="$parentCBOverdue" inherits="OptionsCheckButtonTemplate">
						<Anchors>
							<Anchor point="TOPLEFT" relativeTo="$parentCBReadyTime">
								<Offset><AbsDimension x="0" y="-32"/></Offset>
							</Anchor>
						</Anchors>
						<Scripts>
							<OnLoad>getglobal(this:GetName().."Text"):SetText("Show overdue time");</OnLoad>
							<OnClick>doConfigSave();</OnClick>
							<OnEnter>ConfigTooltip_Show("Shows how long a ready craft", "has been waiting. E.g. +2h 15m");</OnEnter>
							<OnLeave>ConfigTooltip_Hide();</OnLeave>
						</Scripts>
					</CheckButton>

					<!-- CBLastCrafted  y=-200 -->
					<CheckButton name="$parentCBLastCrafted" inherits="OptionsCheckButtonTemplate">
						<Anchors>
							<Anchor point="TOPLEFT" relativeTo="$parentCBOverdue">
								<Offset><AbsDimension x="0" y="-32"/></Offset>
							</Anchor>
						</Anchors>
						<Scripts>
							<OnLoad>getglobal(this:GetName().."Text"):SetText("Show last crafted time");</OnLoad>
							<OnClick>doConfigSave();</OnClick>
							<OnEnter>ConfigTooltip_Show("Shows when you last made this item", "next to each tooltip line.");</OnEnter>
							<OnLeave>ConfigTooltip_Hide();</OnLeave>
						</Scripts>
					</CheckButton>

					<!-- ─── INDICATOR ──────────────── y=-232 ─── -->
					<Frame name="$parentDivDot">
						<Size><AbsDimension x="264" y="14"/></Size>
						<Anchors>
							<Anchor point="TOPLEFT" relativeTo="$parentCBLastCrafted">
								<Offset><AbsDimension x="0" y="-32"/></Offset>
							</Anchor>
						</Anchors>
						<Layers>
							<Layer level="OVERLAY">
								<FontString inherits="GameFontNormalSmall" text="INDICATOR" justifyH="LEFT">
									<Color r="0.35" g="0.75" b="1"/>
									<Anchors><Anchor point="LEFT"/></Anchors>
								</FontString>
								<Texture name="MuteClockDivDot" file="Interface\Buttons\WHITE8X8">
									<Size><AbsDimension x="190" y="1"/></Size>
									<Anchors><Anchor point="RIGHT"/></Anchors>
									<TexCoords left="0" right="1" top="0" bottom="1"/>
								</Texture>
							</Layer>
						</Layers>
					</Frame>

					<!-- SliderSize  y=-254 -->
					<Slider name="$parentSliderSize" inherits="OptionsSliderTemplate">
						<Size><AbsDimension x="234" y="16"/></Size>
						<Anchors>
							<Anchor point="TOPLEFT" relativeTo="$parentDivDot">
								<Offset><AbsDimension x="8" y="-22"/></Offset>
							</Anchor>
						</Anchors>
						<Scripts>
							<OnLoad>
								getglobal(this:GetName().."Text"):SetText("Dot Size (16px)");
								getglobal(this:GetName().."High"):SetText("32");
								getglobal(this:GetName().."Low"):SetText("4");
								this:SetMinMaxValues(4, 32);
								this:SetValueStep(1);
							</OnLoad>
							<OnValueChanged>doConfigSave();</OnValueChanged>
							<OnEnter>ConfigTooltip_Show("Size of the indicator dot in pixels.");</OnEnter>
							<OnLeave>ConfigTooltip_Hide();</OnLeave>
						</Scripts>
					</Slider>

					<!-- CBSmartIcon  y=-298 -->
					<CheckButton name="$parentCBSmartIcon" inherits="OptionsCheckButtonTemplate">
						<Anchors>
							<Anchor point="TOPLEFT" relativeTo="$parentSliderSize">
								<Offset><AbsDimension x="-8" y="-44"/></Offset>
							</Anchor>
						</Anchors>
						<Scripts>
							<OnLoad>getglobal(this:GetName().."Text"):SetText("SmartIcon");</OnLoad>
							<OnClick>doConfigSave();</OnClick>
							<OnEnter>ConfigTooltip_Show("Shows the craft icon instead of the dot", "when a cooldown is ready.");</OnEnter>
							<OnLeave>ConfigTooltip_Hide();</OnLeave>
						</Scripts>
					</CheckButton>

					<!-- CBBadge  y=-330 -->
					<CheckButton name="$parentCBBadge" inherits="OptionsCheckButtonTemplate">
						<Anchors>
							<Anchor point="TOPLEFT" relativeTo="$parentCBSmartIcon">
								<Offset><AbsDimension x="0" y="-32"/></Offset>
							</Anchor>
						</Anchors>
						<Scripts>
							<OnLoad>getglobal(this:GetName().."Text"):SetText("Ready count badge");</OnLoad>
							<OnClick>doConfigSave();</OnClick>
							<OnEnter>ConfigTooltip_Show("Shows a number on the icon", "for how many crafts are ready.");</OnEnter>
							<OnLeave>ConfigTooltip_Hide();</OnLeave>
						</Scripts>
					</CheckButton>

					<!-- CBHide  y=-362 -->
					<CheckButton name="$parentCBHide" inherits="OptionsCheckButtonTemplate">
						<Anchors>
							<Anchor point="TOPLEFT" relativeTo="$parentCBBadge">
								<Offset><AbsDimension x="0" y="-32"/></Offset>
							</Anchor>
						</Anchors>
						<Scripts>
							<OnLoad>getglobal(this:GetName().."Text"):SetText("Hide indicator");</OnLoad>
							<OnClick>doConfigSave();</OnClick>
							<OnEnter>ConfigTooltip_Show("Hides the dot entirely.", "Use /muteclock show to restore it.");</OnEnter>
							<OnLeave>ConfigTooltip_Hide();</OnLeave>
						</Scripts>
					</CheckButton>

					<!-- Reset Defaults  y=-404
					     Placed inside PanelSettings so it only shows on the Settings tab. -->
					<Button name="$parentBtnDefaults" inherits="OptionsButtonTemplate" text="Reset Defaults">
						<Size><AbsDimension x="110" y="22"/></Size>
						<Anchors>
							<Anchor point="TOPLEFT" relativeTo="$parentCBHide">
								<Offset><AbsDimension x="0" y="-42"/></Offset>
							</Anchor>
						</Anchors>
						<Scripts>
							<OnClick>doSetDefaultSettings();</OnClick>
						</Scripts>
					</Button>

				</Frames>
			</Frame>

			<!-- ============================================================
			     HISTORY PANEL
			     Full-height scroll area: 264 x 424
			     ============================================================ -->
			<Frame name="$parentPanelHistory" hidden="true">
				<Size><AbsDimension x="264" y="424"/></Size>
				<Anchors>
					<Anchor point="TOPLEFT" relativeTo="$parent">
						<Offset><AbsDimension x="8" y="-56"/></Offset>
					</Anchor>
				</Anchors>
				<Frames>
					<ScrollFrame name="$parentScrollFrame">
						<Size><AbsDimension x="242" y="416"/></Size>
						<Anchors>
							<Anchor point="TOPLEFT" relativeTo="$parent">
								<Offset><AbsDimension x="0" y="0"/></Offset>
							</Anchor>
						</Anchors>
						<ScrollChild>
							<Frame name="$parentContent">
								<Size><AbsDimension x="242" y="1"/></Size>
							</Frame>
						</ScrollChild>
					</ScrollFrame>
					<Slider name="$parentScrollBar" inherits="UIPanelScrollBarTemplate">
						<Anchors>
							<Anchor point="TOPLEFT" relativeTo="$parentScrollFrame" relativePoint="TOPRIGHT">
								<Offset><AbsDimension x="2" y="-16"/></Offset>
							</Anchor>
							<Anchor point="BOTTOMLEFT" relativeTo="$parentScrollFrame" relativePoint="BOTTOMRIGHT">
								<Offset><AbsDimension x="2" y="16"/></Offset>
							</Anchor>
						</Anchors>
						<Scripts>
							<OnValueChanged>
								MuteClockConfigFramePanelHistoryScrollFrame:SetVerticalScroll(this:GetValue());
							</OnValueChanged>
						</Scripts>
					</Slider>
				</Frames>
			</Frame>

			<!-- ============================================================
			     CRAFTERS PANEL
			     ============================================================ -->
			<Frame name="$parentPanelCrafters" hidden="true">
				<Size><AbsDimension x="264" y="424"/></Size>
				<Anchors>
					<Anchor point="TOPLEFT" relativeTo="$parent">
						<Offset><AbsDimension x="8" y="-56"/></Offset>
					</Anchor>
				</Anchors>
				<Frames>
					<ScrollFrame name="$parentScrollFrame">
						<Size><AbsDimension x="242" y="416"/></Size>
						<Anchors>
							<Anchor point="TOPLEFT" relativeTo="$parent">
								<Offset><AbsDimension x="0" y="0"/></Offset>
							</Anchor>
						</Anchors>
						<ScrollChild>
							<Frame name="$parentContent">
								<Size><AbsDimension x="242" y="1"/></Size>
							</Frame>
						</ScrollChild>
					</ScrollFrame>
					<Slider name="$parentScrollBar" inherits="UIPanelScrollBarTemplate">
						<Anchors>
							<Anchor point="TOPLEFT" relativeTo="$parentScrollFrame" relativePoint="TOPRIGHT">
								<Offset><AbsDimension x="2" y="-16"/></Offset>
							</Anchor>
							<Anchor point="BOTTOMLEFT" relativeTo="$parentScrollFrame" relativePoint="BOTTOMRIGHT">
								<Offset><AbsDimension x="2" y="16"/></Offset>
							</Anchor>
						</Anchors>
						<Scripts>
							<OnValueChanged>
								MuteClockConfigFramePanelCraftersScrollFrame:SetVerticalScroll(this:GetValue());
							</OnValueChanged>
						</Scripts>
					</Slider>
				</Frames>
			</Frame>

			<!-- ============================================================
			     NEARBY PANEL
			     ============================================================ -->
			<Frame name="$parentPanelNearby" hidden="true">
				<Size><AbsDimension x="264" y="424"/></Size>
				<Anchors>
					<Anchor point="TOPLEFT" relativeTo="$parent">
						<Offset><AbsDimension x="8" y="-56"/></Offset>
					</Anchor>
				</Anchors>
				<Frames>
					<ScrollFrame name="$parentScrollFrame">
						<Size><AbsDimension x="242" y="416"/></Size>
						<Anchors>
							<Anchor point="TOPLEFT" relativeTo="$parent">
								<Offset><AbsDimension x="0" y="0"/></Offset>
							</Anchor>
						</Anchors>
						<ScrollChild>
							<Frame name="$parentContent">
								<Size><AbsDimension x="242" y="1"/></Size>
							</Frame>
						</ScrollChild>
					</ScrollFrame>
					<Slider name="$parentScrollBar" inherits="UIPanelScrollBarTemplate">
						<Anchors>
							<Anchor point="TOPLEFT" relativeTo="$parentScrollFrame" relativePoint="TOPRIGHT">
								<Offset><AbsDimension x="2" y="-16"/></Offset>
							</Anchor>
							<Anchor point="BOTTOMLEFT" relativeTo="$parentScrollFrame" relativePoint="BOTTOMRIGHT">
								<Offset><AbsDimension x="2" y="16"/></Offset>
							</Anchor>
						</Anchors>
						<Scripts>
							<OnValueChanged>
								MuteClockConfigFramePanelNearbyScrollFrame:SetVerticalScroll(this:GetValue());
							</OnValueChanged>
						</Scripts>
					</Slider>
				</Frames>
			</Frame>

		</Frames>
		<Scripts>
			<OnLoad>MuteClockConfig_OnLoad();</OnLoad>
			<OnShow>doInitializeConfig(0);</OnShow>
			<OnDragStart>this:StartMoving();</OnDragStart>
			<OnDragStop>this:StopMovingOrSizing();</OnDragStop>
		</Scripts>
	</Frame>

</Ui>
